{
    "Global": {
        "EnvironmentName": "TestLab",
        "DebugMode": false,
        "ToolkitVersion": "1.0.0"
    },
    "Authentication": {
        "Mode": "ConfigFile",
        "ConfigFile": {
            "TenantUrl": "https://testlab.api.identitynow.com",
            "OAuthTokenUrl": "https://testlab.identitynow.com/oauth/token",
            "ClientId": "test-client-id",
            "ClientSecret": "test-client-secret"
        },
        "Vault": {
            "VaultPath": ".\\Data\\sp-vault.enc",
            "Pbkdf2Iterations": 600000,
            "CredentialKey": "sailpoint-isc"
        }
    },
    "Logging": {
        "Path": ".\\Logs",
        "FilePrefix": "GovernanceToolkit",
        "MinimumSeverity": "DEBUG",
        "RetentionDays": 30
    },
    "Api": {
        "BaseUrl": "https://testlab.api.identitynow.com/v3",
        "TimeoutSeconds": 60,
        "RetryCount": 3,
        "RetryDelaySeconds": 5,
        "RateLimitRequestsPerWindow": 95,
        "RateLimitWindowSeconds": 10
    },
    "Testing": {
        "IdentitiesCsvPath": ".\\Config\\test-identities.csv",
        "CampaignsCsvPath": ".\\Config\\test-campaigns.csv",
        "EvidencePath": ".\\Evidence",
        "ReportsPath": ".\\Reports",
        "DecisionBatchSize": 250,
        "ReassignSyncMax": 50,
        "ReassignAsyncMax": 500,
        "CampaignActivationTimeoutSeconds": 300,
        "CampaignCompleteTimeoutSeconds": 600,
        "DefaultDecision": "APPROVE",
        "WhatIfByDefault": false
    },
    "Safety": {
        "MaxCampaignsPerRun": 10,
        "RequireWhatIfOnProd": false,
        "AllowCompleteCampaign": false
    }
}
