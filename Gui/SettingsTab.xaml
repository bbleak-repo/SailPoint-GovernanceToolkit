<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1E1E2E"
    Foreground="#E0E0E0"
    FontFamily="Segoe UI"
    FontSize="13">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BrushBackground"  Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BrushSurface"     Color="#2D2D44"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt"  Color="#252538"/>
        <SolidColorBrush x:Key="BrushPrimary"     Color="#5B9BD5"/>
        <SolidColorBrush x:Key="BrushSuccess"     Color="#339933"/>
        <SolidColorBrush x:Key="BrushError"       Color="#CC3333"/>
        <SolidColorBrush x:Key="BrushWarning"     Color="#FF9900"/>
        <SolidColorBrush x:Key="BrushText"        Color="#E0E0E0"/>
        <SolidColorBrush x:Key="BrushTextMuted"   Color="#888899"/>
        <SolidColorBrush x:Key="BrushBorder"      Color="#3D3D5C"/>

        <!-- Field label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#AAAACC"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"      Value="0,0,0,2"/>
            <Setter Property="Width"       Value="200"/>
        </Style>

        <!-- Field TextBox style -->
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"           Value="#2D2D44"/>
            <Setter Property="Foreground"           Value="#E0E0E0"/>
            <Setter Property="BorderBrush"          Value="#3D3D5C"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,4"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height"               Value="30"/>
        </Style>

        <!-- PasswordBox style -->
        <Style x:Key="FieldPassword" TargetType="PasswordBox">
            <Setter Property="Background"           Value="#2D2D44"/>
            <Setter Property="Foreground"           Value="#E0E0E0"/>
            <Setter Property="BorderBrush"          Value="#3D3D5C"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,4"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="Height"               Value="30"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background"           Value="#2D2D44"/>
            <Setter Property="Foreground"           Value="#E0E0E0"/>
            <Setter Property="BorderBrush"          Value="#3D3D5C"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="8,4"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="Height"               Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#5B9BD5"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,16,0,8"/>
        </Style>

        <!-- Section border style -->
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="BorderBrush"     Value="#3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,12"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <!-- Action buttons -->
        <Style x:Key="ToolkitButton" TargetType="Button">
            <Setter Property="Background"      Value="#5B9BD5"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6DACE0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A85BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolkitButton}">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="BorderBrush"     Value="#5B9BD5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- Scrollable form -->
            <RowDefinition Height="Auto"/>  <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- Scrollable settings form -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel Margin="0,4,0,8">

                <!-- Environment Section -->
                <TextBlock Text="Environment" Style="{StaticResource SectionHeader}" Margin="0,4,0,8"/>
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Environment Name"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtEnvironmentName"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="Logical label for this environment (e.g. Sandbox, Production)"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Debug Mode"
                                   Style="{StaticResource FieldLabel}"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="ChkDebugMode"
                                  Foreground="#E0E0E0" FontSize="12"
                                  VerticalAlignment="Center"
                                  ToolTip="Enable verbose debug logging"/>
                    </Grid>
                </Border>

                <!-- Authentication Section -->
                <TextBlock Text="Authentication" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>  <!-- Vault note -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Authentication Mode"
                                   Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CboAuthMode"
                                  Style="{StaticResource FieldCombo}"
                                  ToolTip="ConfigFile stores credentials in settings.json. Vault uses encrypted vault file.">
                            <ComboBoxItem Content="ConfigFile"/>
                            <ComboBoxItem Content="Vault"/>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tenant URL"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtTenantUrl"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="https://&lt;tenant&gt;.api.identitynow.com"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Client ID"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtClientId"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="OAuth 2.0 client_credentials ClientId (used when Mode=ConfigFile)"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Client Secret"
                                   Style="{StaticResource FieldLabel}"/>
                        <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="PbClientSecret"
                                     Style="{StaticResource FieldPassword}"
                                     ToolTip="Client Secret (only visible in ConfigFile mode - prefer Vault for production)"/>

                        <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                                Background="#252538" CornerRadius="4" Padding="10,6">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF9900">
                                For production environments, use Authentication Mode = Vault and run New-SPVault.ps1 to store credentials securely. The Client Secret field above is only for ConfigFile mode.
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- API Section -->
                <TextBlock Text="API Configuration" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Left column -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="API Base URL"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtApiBaseUrl"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="https://&lt;tenant&gt;.api.identitynow.com/v3"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Timeout (seconds)"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtApiTimeout"
                                 Style="{StaticResource FieldBox}" Text="60"
                                 ToolTip="HTTP request timeout in seconds"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Retry Count"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtRetryCount"
                                 Style="{StaticResource FieldBox}" Text="3"
                                 ToolTip="Number of retries on 429/5xx responses"/>

                        <!-- Right column -->
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Rate Limit (req/window)"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtRateLimit"
                                 Style="{StaticResource FieldBox}" Text="95"
                                 ToolTip="Max requests per window (ISC limit: 95/10s)"/>

                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Rate Window (seconds)"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtRateWindow"
                                 Style="{StaticResource FieldBox}" Text="10"
                                 ToolTip="Rate limit window in seconds"/>

                        <TextBlock Grid.Row="4" Grid.Column="3" Text="Retry Delay (seconds)"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="4" Grid.Column="4" x:Name="TxtRetryDelay"
                                 Style="{StaticResource FieldBox}" Text="5"
                                 ToolTip="Seconds to wait between retries on server errors"/>
                    </Grid>
                </Border>

                <!-- Testing Section -->
                <TextBlock Text="Testing" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Identities CSV Path"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtIdentitiesCsvPath"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="Path to test-identities.csv (relative to toolkit root or absolute)"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Browse"
                                x:Name="BtnBrowseIdentities"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Campaigns CSV Path"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtCampaignsCsvPath"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="Path to test-campaigns.csv (relative to toolkit root or absolute)"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="Browse"
                                x:Name="BtnBrowseCampaigns"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Evidence Path"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtEvidencePath"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="Directory where JSONL evidence files are written"/>
                        <Button Grid.Row="4" Grid.Column="2" Content="Browse"
                                x:Name="BtnBrowseEvidence"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Reports Path"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtReportsPath"
                                 Style="{StaticResource FieldBox}"
                                 ToolTip="Directory where HTML reports are written"/>
                        <Button Grid.Row="6" Grid.Column="2" Content="Browse"
                                x:Name="BtnBrowseReports"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Quick Connect: Browser Token Section -->
                <TextBlock Text="Quick Connect - Browser Token" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox Grid.Column="0" x:Name="PbBrowserToken"
                                         Style="{StaticResource FieldPassword}"
                                         PasswordChar="*"
                                         ToolTip="Paste JWT from browser dev tools (F12 > Network tab > copy Authorization header value)"/>

                            <Button Grid.Column="2" x:Name="BtnApplyToken"
                                    Content="Apply Token"
                                    Style="{StaticResource ToolkitButton}"/>

                            <Button Grid.Column="4" x:Name="BtnClearToken"
                                    Content="Clear"
                                    Style="{StaticResource SecondaryButton}"/>
                        </Grid>

                        <TextBlock Grid.Row="2" x:Name="BrowserTokenStatus"
                                   Foreground="#888899" FontSize="11" TextWrapping="Wrap"
                                   Text="No browser token active. Paste a JWT from the ISC admin console to bypass OAuth credentials."/>
                    </Grid>
                </Border>

                <!-- Safety Section -->
                <TextBlock Text="Safety Controls" Style="{StaticResource SectionHeader}"/>
                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>  <!-- Safety note -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Campaigns Per Run"
                                   Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtMaxCampaignsPerRun"
                                 Style="{StaticResource FieldBox}" Text="10" Width="80"
                                 HorizontalAlignment="Left"
                                 ToolTip="Hard limit on campaigns per execution (prevents runaway test runs)"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Require WhatIf on Prod"
                                   Style="{StaticResource FieldLabel}"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="ChkRequireWhatIf"
                                  IsChecked="True" Foreground="#E0E0E0" FontSize="12"
                                  VerticalAlignment="Center"
                                  ToolTip="Forces confirmation before running against a RequireWhatIfOnProd=true environment"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Allow Complete Campaign"
                                   Style="{StaticResource FieldLabel}"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="ChkAllowComplete"
                                  IsChecked="False" Foreground="#E0E0E0" FontSize="12"
                                  VerticalAlignment="Center"
                                  ToolTip="Allow tests to call POST /campaigns/{id}/complete (only works on past-due campaigns)"/>

                        <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                Background="#252538" CornerRadius="4" Padding="10,6">
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF9900">
                                Safety controls are enforced at runtime by Invoke-GovernanceTest.ps1. AllowCompleteCampaign should remain false unless you are explicitly testing campaign completion on a past-due campaign in a non-production environment.
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action bar -->
        <Border Grid.Row="1" Background="#252538" BorderBrush="#3D3D5C"
                BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnSaveSettings"
                        Content="Save Settings" Style="{StaticResource ToolkitButton}"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="BtnResetDefaults"
                        Content="Reset to Defaults" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3" x:Name="BtnTestConnectivity"
                        Content="Test Connectivity" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4" x:Name="ConnectivityStatusText"
                           Foreground="#AAAACC" VerticalAlignment="Center"
                           MaxWidth="320" TextWrapping="Wrap" FontSize="12"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
