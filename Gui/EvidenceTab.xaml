<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1E1E2E"
    Foreground="#E0E0E0"
    FontFamily="Segoe UI"
    FontSize="13">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BrushBackground"  Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BrushSurface"     Color="#2D2D44"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt"  Color="#252538"/>
        <SolidColorBrush x:Key="BrushPrimary"     Color="#5B9BD5"/>
        <SolidColorBrush x:Key="BrushText"        Color="#E0E0E0"/>
        <SolidColorBrush x:Key="BrushTextMuted"   Color="#888899"/>
        <SolidColorBrush x:Key="BrushBorder"      Color="#3D3D5C"/>

        <Style x:Key="ToolkitButton" TargetType="Button">
            <Setter Property="Background"      Value="#5B9BD5"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6DACE0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A85BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolkitButton}">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="BorderBrush"     Value="#5B9BD5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- TreeViewItem style -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"  Value="#E0E0E0"/>
            <Setter Property="Padding"     Value="4,2"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A58"/>
                    <Setter Property="Foreground" Value="#5B9BD5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#323250"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>   <!-- Tree panel -->
            <ColumnDefinition Width="8"/>     <!-- Splitter -->
            <ColumnDefinition Width="*"/>     <!-- Detail panel -->
        </Grid.ColumnDefinitions>

        <!-- Left: Evidence Tree Panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header + Refresh -->
                <RowDefinition Height="*"/>     <!-- TreeView -->
                <RowDefinition Height="Auto"/>  <!-- File info -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Evidence Files"
                           Foreground="#5B9BD5" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="BtnRefreshEvidence"
                        Content="Refresh" Style="{StaticResource SecondaryButton}"
                        Padding="10,4" FontSize="11"/>
            </Grid>

            <!-- TreeView -->
            <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                    BorderBrush="#3D3D5C" BorderThickness="1">
                <TreeView x:Name="EvidenceTree"
                          Background="Transparent"
                          Foreground="#E0E0E0"
                          BorderThickness="0"
                          Margin="4">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                         Color="#3A3A58"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                         Color="#5B9BD5"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                         Color="#2D2D44"/>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <!-- Selected file info -->
            <Border Grid.Row="2" Background="#252538" CornerRadius="4"
                    BorderBrush="#3D3D5C" BorderThickness="1" Margin="0,6,0,0" Padding="8,4">
                <TextBlock x:Name="SelectedFilePath" Text="No file selected"
                           Foreground="#888899" FontSize="11"
                           TextWrapping="Wrap" TextTrimming="None"/>
            </Border>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                      Background="#1E1E2E" Cursor="SizeWE"/>

        <!-- Right: Detail Panel -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header + actions -->
                <RowDefinition Height="Auto"/>  <!-- Tab selector (JSONL / HTML) -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Event count footer -->
            </Grid.RowDefinitions>

            <!-- Header + action buttons -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Evidence Detail"
                           Foreground="#5B9BD5" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="BtnOpenInBrowser"
                        Content="Open in Browser" Style="{StaticResource SecondaryButton}"
                        Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                <Button Grid.Column="2" x:Name="BtnCopyPath"
                        Content="Copy Path" Style="{StaticResource SecondaryButton}"
                        Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                <Button Grid.Column="3" x:Name="BtnExportAll"
                        Content="Export All" Style="{StaticResource SecondaryButton}"
                        Padding="10,4" FontSize="11"/>
            </Grid>

            <!-- View mode selector -->
            <Border Grid.Row="1" Background="#252538" CornerRadius="4"
                    BorderBrush="#3D3D5C" BorderThickness="1" Margin="0,0,0,8" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="View mode:" Foreground="#AAAACC" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <RadioButton x:Name="RbViewJsonl" Content="JSONL Events"
                                     Foreground="#E0E0E0" FontSize="12"
                                     IsChecked="True" Margin="0,0,12,0"
                                     VerticalContentAlignment="Center"/>
                        <RadioButton x:Name="RbViewRaw" Content="Raw Text"
                                     Foreground="#E0E0E0" FontSize="12"
                                     VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <TextBox Grid.Column="2" x:Name="TxtEventFilter" Width="180"
                             Background="#2D2D44" Foreground="#E0E0E0"
                             BorderBrush="#3D3D5C" FontSize="12"
                             Padding="6,3" VerticalContentAlignment="Center"
                             Text="Filter events..."/>
                </Grid>
            </Border>

            <!-- Content area: JSONL DataGrid -->
            <Border Grid.Row="2" Background="#2D2D44" CornerRadius="6"
                    BorderBrush="#3D3D5C" BorderThickness="1">
                <Grid>
                    <!-- JSONL grid view -->
                    <DataGrid x:Name="EvidenceDetailGrid"
                              AutoGenerateColumns="True"
                              Background="Transparent"
                              Foreground="#E0E0E0"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#3D3D5C"
                              RowBackground="#2D2D44"
                              AlternatingRowBackground="#252538"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              ColumnHeaderHeight="32"
                              RowHeight="26"
                              SelectionMode="Single"
                              Margin="2">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"        Value="#252538"/>
                                <Setter Property="Foreground"        Value="#5B9BD5"/>
                                <Setter Property="FontWeight"        Value="SemiBold"/>
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="BorderThickness"   Value="0,0,1,1"/>
                                <Setter Property="BorderBrush"       Value="#3D3D5C"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Height"            Value="32"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3A3A58"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <!-- Raw text view (hidden by default) -->
                    <TextBox x:Name="RawTextView"
                             Visibility="Collapsed"
                             Background="#1A1A2E"
                             Foreground="#AACCFF"
                             FontFamily="Consolas, Courier New"
                             FontSize="11"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Padding="8"/>
                </Grid>
            </Border>

            <!-- Event count footer -->
            <Border Grid.Row="3" Background="#252538" CornerRadius="4"
                    BorderBrush="#3D3D5C" BorderThickness="1" Margin="0,6,0,0" Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="EvidenceStatusText"
                               Text="Select a file in the tree to view evidence events."
                               Foreground="#888899" FontSize="11"/>
                    <TextBlock Grid.Column="1" x:Name="EventCountLabel"
                               Text="" Foreground="#5B9BD5" FontSize="11"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
