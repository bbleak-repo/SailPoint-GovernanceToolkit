<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="MainWindowRoot"
    Title="SailPoint ISC Governance Toolkit"
    Width="1100"
    Height="640"
    MinWidth="860"
    MinHeight="480"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E2E"
    Foreground="#E0E0E0"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <!-- Color palette -->
        <SolidColorBrush x:Key="BrushBackground"  Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BrushSurface"     Color="#2D2D44"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt"  Color="#252538"/>
        <SolidColorBrush x:Key="BrushPrimary"     Color="#5B9BD5"/>
        <SolidColorBrush x:Key="BrushSuccess"     Color="#339933"/>
        <SolidColorBrush x:Key="BrushError"       Color="#CC3333"/>
        <SolidColorBrush x:Key="BrushWarning"     Color="#FF9900"/>
        <SolidColorBrush x:Key="BrushText"        Color="#E0E0E0"/>
        <SolidColorBrush x:Key="BrushTextMuted"   Color="#888899"/>
        <SolidColorBrush x:Key="BrushBorder"      Color="#3D3D5C"/>
        <SolidColorBrush x:Key="BrushTabSelected" Color="#3A3A58"/>

        <!-- Base button style -->
        <Style x:Key="ToolkitButton" TargetType="Button">
            <Setter Property="Background"        Value="#5B9BD5"/>
            <Setter Property="Foreground"        Value="#FFFFFF"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="14,6"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6DACE0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A85BB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3D3D5C"/>
                                <Setter Property="Foreground" Value="#666677"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (outline style) -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolkitButton}">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="BorderBrush"     Value="#5B9BD5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Tab item style -->
        <Style x:Key="ToolkitTabItem" TargetType="TabItem">
            <Setter Property="Background"   Value="#2D2D44"/>
            <Setter Property="Foreground"   Value="#AAAACC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="20,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#3A3A58"/>
                                <Setter Property="Foreground" Value="#5B9BD5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#323250"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu style -->
        <Style TargetType="Menu">
            <Setter Property="Background"   Value="#252538"/>
            <Setter Property="Foreground"   Value="#E0E0E0"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background"   Value="#252538"/>
            <Setter Property="Foreground"   Value="#E0E0E0"/>
        </Style>

        <!-- ScrollBar style (minimal) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2D2D44"/>
            <Setter Property="Foreground" Value="#5B9BD5"/>
        </Style>

        <!-- Settings form field styles (inlined from SettingsTab.xaml) -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#AAAACC"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,0,2"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#2D2D44"/>
            <Setter Property="Foreground"               Value="#E0E0E0"/>
            <Setter Property="BorderBrush"              Value="#3D3D5C"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="8,4"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height"                   Value="30"/>
        </Style>

        <Style x:Key="FieldPassword" TargetType="PasswordBox">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="Foreground"      Value="#E0E0E0"/>
            <Setter Property="BorderBrush"     Value="#3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="30"/>
        </Style>

        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background"               Value="#2D2D44"/>
            <Setter Property="Foreground"               Value="#E0E0E0"/>
            <Setter Property="BorderBrush"              Value="#3D3D5C"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="8,4"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B9BD5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,16,0,8"/>
        </Style>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="BorderBrush"     Value="#3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,12"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu bar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="28"/>    <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Menu Bar + right-aligned Close button -->
        <Grid Grid.Row="0" Background="#252538">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Menu Grid.Column="0" Background="#252538" Padding="4,2">
                <MenuItem Header="File">
                    <MenuItem x:Name="MenuExit" Header="Exit" InputGestureText="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="Tools">
                    <MenuItem x:Name="MenuTestConnectivity" Header="Test Connectivity"/>
                    <Separator/>
                    <MenuItem x:Name="MenuNewVault"         Header="New Vault Setup..."/>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem x:Name="MenuAbout" Header="About"/>
                </MenuItem>
            </Menu>
            <Button Grid.Column="1" x:Name="BtnCloseApp" Content="✕  Close"
                    Background="#8B2E2E" Foreground="#FFFFFF"
                    BorderBrush="#C04040" BorderThickness="1"
                    Padding="14,4" FontSize="12" FontWeight="SemiBold"
                    FontFamily="Segoe UI" Cursor="Hand"
                    Margin="4,2,6,2" VerticalAlignment="Center"
                    ToolTip="Close the dashboard (Alt+F4)"/>
        </Grid>

        <!-- Main Tab Control -->
        <TabControl x:Name="MainTabControl"
                    Grid.Row="1"
                    Background="#1E1E2E"
                    BorderThickness="0"
                    Margin="0">

            <!-- Campaign Tab -->
            <TabItem Header="Campaigns" Style="{StaticResource ToolkitTabItem}">
                <Grid x:Name="CampaignTabContent" Background="#1E1E2E" Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                        <RowDefinition Height="*"/>     <!-- DataGrid -->
                        <RowDefinition Height="Auto"/>  <!-- Progress + results -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnRunSelected" Content="Run Selected"
                                Style="{StaticResource ToolkitButton}" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" x:Name="BtnRunAll" Content="Run All"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
                        <Button Grid.Column="2" x:Name="BtnRunSmoke" Content="Run Smoke"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>

                        <!-- Spacer -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="Tag:" Foreground="#AAAACC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="TagFilterCombo" Width="130" Background="#2D2D44"
                                      Foreground="#E0E0E0" BorderBrush="#3D3D5C"/>
                        </StackPanel>

                        <Button Grid.Column="5" x:Name="BtnRefreshCampaigns" Content="Refresh"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,0,0"/>
                    </Grid>

                    <!-- Campaign DataGrid -->
                    <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                            BorderBrush="#3D3D5C" BorderThickness="1">
                        <DataGrid x:Name="CampaignGrid"
                                  AutoGenerateColumns="False"
                                  Background="#2D2D44"
                                  Foreground="#E0E0E0"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#3D3D5C"
                                  RowBackground="#2D2D44"
                                  AlternatingRowBackground="#252538"
                                  SelectionMode="Extended"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="32"
                                  RowHeight="28"
                                  Margin="2">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"   Value="#252538"/>
                                    <Setter Property="Foreground"   Value="#5B9BD5"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                    <Setter Property="Padding"      Value="8,4"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"  Value="#3D3D5C"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn  Header=""         Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                                <DataGridTextColumn      Header="Test ID"  Binding="{Binding TestId}"         Width="90"  IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Test Name" Binding="{Binding TestName}"       Width="*"   IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Type"     Binding="{Binding CampaignType}"   Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Decision"  Binding="{Binding DecisionToMake}" Width="80"  IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Priority" Binding="{Binding Priority}"       Width="70"  IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Tags"     Binding="{Binding Tags}"           Width="140" IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Status"   Binding="{Binding Status}"         Width="80"  IsReadOnly="True"/>
                                <DataGridTextColumn      Header="Result"   Binding="{Binding LastResult}"     Width="90"  IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Progress + Results -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="CurrentTestLabel"
                                       Foreground="#AAAACC" VerticalAlignment="Center"
                                       Margin="0,0,12,0" FontSize="12"/>
                            <ProgressBar Grid.Column="1" x:Name="SuiteProgressBar"
                                         Height="10" Background="#252538"
                                         Foreground="#5B9BD5"
                                         BorderBrush="#3D3D5C" BorderThickness="1"
                                         Visibility="Collapsed"/>
                        </Grid>

                        <TextBlock Grid.Row="1" x:Name="ResultSummaryText"
                                   Foreground="#AAAACC" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Evidence Tab -->
            <TabItem Header="Evidence" Style="{StaticResource ToolkitTabItem}">
                <Grid x:Name="EvidenceTabContent" Background="#1E1E2E" Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>   <!-- Tree view -->
                        <ColumnDefinition Width="8"/>     <!-- Splitter -->
                        <ColumnDefinition Width="*"/>     <!-- Detail panel -->
                    </Grid.ColumnDefinitions>

                    <!-- Evidence tree panel -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Evidence Files"
                                       Foreground="#5B9BD5" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Name="BtnRefreshEvidence"
                                    Content="Refresh" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11"/>
                        </Grid>

                        <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                                BorderBrush="#3D3D5C" BorderThickness="1">
                            <TreeView x:Name="EvidenceTree"
                                      Background="Transparent"
                                      Foreground="#E0E0E0"
                                      BorderThickness="0"
                                      Margin="4"/>
                        </Border>
                    </Grid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center"
                                  Background="#1E1E2E" Cursor="SizeWE"/>

                    <!-- Detail panel -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Evidence Detail"
                                       Foreground="#5B9BD5" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Name="BtnOpenInBrowser"
                                    Content="Open in Browser" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                            <Button Grid.Column="2" x:Name="BtnExportAll"
                                    Content="Export All" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11"/>
                        </Grid>

                        <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                                BorderBrush="#3D3D5C" BorderThickness="1">
                            <DataGrid x:Name="EvidenceDetailGrid"
                                      AutoGenerateColumns="True"
                                      Background="Transparent"
                                      Foreground="#E0E0E0"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#3D3D5C"
                                      RowBackground="#2D2D44"
                                      AlternatingRowBackground="#252538"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      ColumnHeaderHeight="30"
                                      RowHeight="26"
                                      Margin="2">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"  Value="#252538"/>
                                        <Setter Property="Foreground"  Value="#5B9BD5"/>
                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                        <Setter Property="Padding"     Value="8,4"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#3D3D5C"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings" Style="{StaticResource ToolkitTabItem}">
                <Grid x:Name="SettingsTabContent" Background="#1E1E2E" Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Settings form (inlined; previous ContentControl injection was never wired up) -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,4">

                            <!-- Environment -->
                            <TextBlock Text="Environment" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource SectionBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Environment Name" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtEnvironmentName" Style="{StaticResource FieldBox}"
                                               ToolTip="Logical label for this environment (e.g. Sandbox, Production)"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Debug Mode" Style="{StaticResource FieldLabel}"/>
                                    <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="ChkDebugMode"
                                               Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"
                                               ToolTip="Enable verbose debug logging"/>
                                </Grid>
                            </Border>

                            <!-- Authentication -->
                            <TextBlock Text="Authentication" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource SectionBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Authentication Mode" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CboAuthMode" Style="{StaticResource FieldCombo}"
                                               ToolTip="ConfigFile stores credentials in settings.json. Vault uses encrypted vault file.">
                                        <ComboBoxItem Content="ConfigFile"/>
                                        <ComboBoxItem Content="Vault"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tenant URL" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtTenantUrl" Style="{StaticResource FieldBox}"
                                               ToolTip="https://&lt;tenant&gt;.api.identitynow.com"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Client ID" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtClientId" Style="{StaticResource FieldBox}"
                                               ToolTip="OAuth 2.0 client_credentials ClientId (used when Mode=ConfigFile)"/>

                                    <TextBlock   Grid.Row="6" Grid.Column="0" Text="Client Secret" Style="{StaticResource FieldLabel}"/>
                                    <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="PbClientSecret" Style="{StaticResource FieldPassword}"
                                                 ToolTip="Client Secret (only visible in ConfigFile mode; prefer Vault for production)"/>

                                    <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="#252538" CornerRadius="4" Padding="10,6">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF9900">
                                            For production environments, use Authentication Mode = Vault and run New-SPVault.ps1 to store credentials securely. The Client Secret field above is only for ConfigFile mode.
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- API -->
                            <TextBlock Text="API Configuration" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource SectionBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="API Base URL" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtApiBaseUrl" Style="{StaticResource FieldBox}"
                                               ToolTip="https://&lt;tenant&gt;.api.identitynow.com/v3"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Timeout (seconds)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtApiTimeout" Style="{StaticResource FieldBox}" Text="60"
                                               ToolTip="HTTP request timeout in seconds"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Retry Count" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtRetryCount" Style="{StaticResource FieldBox}" Text="3"
                                               ToolTip="Number of retries on 429/5xx responses"/>

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Rate Limit (req/window)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="4" x:Name="TxtRateLimit" Style="{StaticResource FieldBox}" Text="95"
                                               ToolTip="Max requests per window (ISC limit: 95/10s)"/>

                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Rate Window (seconds)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="4" x:Name="TxtRateWindow" Style="{StaticResource FieldBox}" Text="10"
                                               ToolTip="Rate limit window in seconds"/>

                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Retry Delay (seconds)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="4" Grid.Column="4" x:Name="TxtRetryDelay" Style="{StaticResource FieldBox}" Text="5"
                                               ToolTip="Seconds to wait between retries on server errors"/>
                                </Grid>
                            </Border>

                            <!-- Testing / Paths -->
                            <TextBlock Text="Testing" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource SectionBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Identities CSV Path" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtIdentitiesCsvPath" Style="{StaticResource FieldBox}"
                                               ToolTip="Path to test-identities.csv (relative to toolkit root or absolute)"/>
                                    <Button    Grid.Row="0" Grid.Column="2" x:Name="BtnBrowseIdentities" Content="Browse"
                                               Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Margin="6,0,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Campaigns CSV Path" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtCampaignsCsvPath" Style="{StaticResource FieldBox}"
                                               ToolTip="Path to test-campaigns.csv (relative to toolkit root or absolute)"/>
                                    <Button    Grid.Row="2" Grid.Column="2" x:Name="BtnBrowseCampaigns" Content="Browse"
                                               Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Margin="6,0,0,0"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Evidence Path" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtEvidencePath" Style="{StaticResource FieldBox}"
                                               ToolTip="Directory where JSONL evidence files are written"/>
                                    <Button    Grid.Row="4" Grid.Column="2" x:Name="BtnBrowseEvidence" Content="Browse"
                                               Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Margin="6,0,0,0"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Reports Path" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="6" Grid.Column="1" x:Name="TxtReportsPath" Style="{StaticResource FieldBox}"
                                               ToolTip="Directory where HTML reports are written"/>
                                    <Button    Grid.Row="6" Grid.Column="2" x:Name="BtnBrowseReports" Content="Browse"
                                               Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Safety -->
                            <TextBlock Text="Safety Controls" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource SectionBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Campaigns Per Run" Style="{StaticResource FieldLabel}"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtMaxCampaignsPerRun" Style="{StaticResource FieldBox}"
                                               Text="10" Width="80" HorizontalAlignment="Left"
                                               ToolTip="Hard limit on campaigns per execution (prevents runaway test runs)"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Require WhatIf on Prod" Style="{StaticResource FieldLabel}"/>
                                    <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="ChkRequireWhatIf"
                                               IsChecked="True" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"
                                               ToolTip="Forces confirmation before running against an environment with RequireWhatIfOnProd=true"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Allow Complete Campaign" Style="{StaticResource FieldLabel}"/>
                                    <CheckBox  Grid.Row="4" Grid.Column="1" x:Name="ChkAllowComplete"
                                               IsChecked="False" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"
                                               ToolTip="Allow tests to call POST /campaigns/{id}/complete (only works on past-due campaigns)"/>

                                    <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="#252538" CornerRadius="4" Padding="10,6">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF9900">
                                            Safety controls are enforced at runtime by Invoke-GovernanceTest.ps1. AllowCompleteCampaign should remain false unless you are explicitly testing campaign completion on a past-due campaign in a non-production environment.
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Quick Connect: Browser Token -->
                    <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                            BorderBrush="#3D3D5C" BorderThickness="1"
                            Padding="16,12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Quick Connect - Browser Token"
                                       Foreground="#5B9BD5" FontWeight="SemiBold" FontSize="13"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <PasswordBox Grid.Column="0" x:Name="PbBrowserToken"
                                             Background="#252538" Foreground="#E0E0E0"
                                             BorderBrush="#3D3D5C" BorderThickness="1"
                                             Padding="8,4" FontSize="12" Height="30"
                                             PasswordChar="*"
                                             ToolTip="Paste JWT from browser dev tools (F12 > Network tab > copy Authorization header value)"/>

                                <Button Grid.Column="2" x:Name="BtnApplyToken"
                                        Content="Apply Token"
                                        Background="#5B9BD5" Foreground="#FFFFFF"
                                        BorderThickness="0" Padding="14,6"
                                        FontSize="12" FontFamily="Segoe UI" Cursor="Hand"/>

                                <Button Grid.Column="4" x:Name="BtnClearToken"
                                        Content="Clear"
                                        Background="#2D2D44" Foreground="#E0E0E0"
                                        BorderBrush="#5B9BD5" BorderThickness="1"
                                        Padding="14,6" FontSize="12" FontFamily="Segoe UI" Cursor="Hand"/>
                            </Grid>

                            <TextBlock Grid.Row="4" x:Name="BrowserTokenStatus"
                                       Foreground="#888899" FontSize="11" TextWrapping="Wrap"
                                       Text="No browser token active. Paste a JWT from the ISC admin console to bypass OAuth credentials."/>
                        </Grid>
                    </Border>

                    <!-- Bottom button bar -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnSaveSettings"
                                Content="Save Settings" Style="{StaticResource ToolkitButton}"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="1" x:Name="BtnResetDefaults"
                                Content="Reset to Defaults" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0"/>

                        <Button Grid.Column="3" x:Name="BtnTestConnectivity"
                                Content="Test Connectivity" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="4" x:Name="ConnectivityStatusText"
                                   Foreground="#AAAACC" VerticalAlignment="Center"
                                   MaxWidth="300" TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Audit Tab -->
            <TabItem Header="Audit" Style="{StaticResource ToolkitTabItem}">
                <Grid x:Name="AuditTabContent" Background="#1E1E2E" Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Row 0: Query filters -->
                        <RowDefinition Height="*"/>     <!-- Row 1: Campaign results DataGrid -->
                        <RowDefinition Height="Auto"/>  <!-- Row 2: Audit options + run buttons -->
                        <RowDefinition Height="Auto"/>  <!-- Row 3: Progress bar + status label -->
                        <RowDefinition Height="Auto"/>  <!-- Row 4: Recent audit reports -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Query filters -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Campaign:" Foreground="#AAAACC"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>

                        <TextBox Grid.Column="1" x:Name="TxtAuditCampaignName"
                                 Width="200" Background="#2D2D44" Foreground="#888899"
                                 BorderBrush="#3D3D5C" BorderThickness="1"
                                 Padding="6,4" FontSize="12"
                                 Text="Search by keyword..."
                                 Margin="0,0,8,0"/>

                        <TextBlock Grid.Column="2" Text="Status:" Foreground="#AAAACC"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>

                        <ComboBox Grid.Column="3" x:Name="CboAuditStatus"
                                  Width="120" Background="#2D2D44"
                                  Foreground="#E0E0E0" BorderBrush="#3D3D5C"
                                  SelectedIndex="0" Margin="0,0,8,0" FontSize="12">
                            <ComboBoxItem Content="(All)" IsSelected="True"/>
                            <ComboBoxItem Content="COMPLETED"/>
                            <ComboBoxItem Content="ACTIVE"/>
                            <ComboBoxItem Content="STAGED"/>
                            <ComboBoxItem Content="COMPLETING"/>
                        </ComboBox>

                        <TextBlock Grid.Column="4" Text="Timespan:" Foreground="#AAAACC"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>

                        <ComboBox Grid.Column="5" x:Name="CboAuditTimespan"
                                  Width="90" Background="#2D2D44"
                                  Foreground="#E0E0E0" BorderBrush="#3D3D5C"
                                  SelectedIndex="2" Margin="0,0,8,0" FontSize="12">
                            <ComboBoxItem Content="1 day"  Tag="1"/>
                            <ComboBoxItem Content="2 days" Tag="2"/>
                            <ComboBoxItem Content="3 days" Tag="3" IsSelected="True"/>
                            <ComboBoxItem Content="5 days" Tag="5"/>
                        </ComboBox>

                        <!-- Spacer -->
                        <StackPanel Grid.Column="6"/>

                        <Button Grid.Column="7" x:Name="BtnQueryCampaigns"
                                Content="Query Campaigns"
                                Style="{StaticResource ToolkitButton}"
                                Margin="0,0,6,0"/>

                        <Button Grid.Column="8" x:Name="BtnClearFilter"
                                Content="Clear"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>

                    <!-- Row 1: Campaign results DataGrid -->
                    <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                            BorderBrush="#3D3D5C" BorderThickness="1" Margin="0,0,0,8">
                        <DataGrid x:Name="AuditCampaignGrid"
                                  AutoGenerateColumns="False"
                                  Background="#2D2D44"
                                  Foreground="#E0E0E0"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#3D3D5C"
                                  RowBackground="#2D2D44"
                                  AlternatingRowBackground="#252538"
                                  SelectionMode="Extended"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="32"
                                  RowHeight="28"
                                  Margin="2">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#252538"/>
                                    <Setter Property="Foreground"      Value="#5B9BD5"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Padding"         Value="8,4"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"     Value="#3D3D5C"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header=""
                                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="55"/>
                                <DataGridTextColumn Header="Campaign Name"
                                                    Binding="{Binding CampaignName}"
                                                    Width="*"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="100"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Created"
                                                    Binding="{Binding Created}"
                                                    Width="140"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Completed"
                                                    Binding="{Binding Completed}"
                                                    Width="140"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Certs"
                                                    Binding="{Binding TotalCertifications}"
                                                    Width="55"
                                                    IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Row 2: Audit options + run buttons -->
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" x:Name="ChkCampaignReports"
                                  Content="Include Campaign Reports"
                                  Foreground="#E0E0E0" VerticalAlignment="Center"
                                  IsChecked="True" Margin="0,0,16,0" FontSize="12"/>

                        <CheckBox Grid.Column="1" x:Name="ChkIdentityEvents"
                                  Content="Include Identity Events"
                                  Foreground="#E0E0E0" VerticalAlignment="Center"
                                  IsChecked="True" Margin="0,0,8,0" FontSize="12"/>

                        <!-- Spacer -->
                        <StackPanel Grid.Column="2"/>

                        <Button Grid.Column="3" x:Name="BtnRunAudit"
                                Content="Run Audit"
                                Style="{StaticResource ToolkitButton}"
                                IsEnabled="False"
                                Margin="0,0,6,0"/>

                        <Button Grid.Column="4" x:Name="BtnOpenAuditFolder"
                                Content="Open Reports Folder"
                                Style="{StaticResource SecondaryButton}"/>
                    </Grid>

                    <!-- Row 3: Progress bar + status label -->
                    <Grid Grid.Row="3" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="AuditStatusLabel"
                                   Foreground="#AAAACC" VerticalAlignment="Center"
                                   FontSize="12" Margin="0,0,12,0"/>

                        <ProgressBar Grid.Column="1" x:Name="AuditProgressBar"
                                     Height="10" Background="#252538"
                                     Foreground="#5B9BD5"
                                     BorderBrush="#3D3D5C" BorderThickness="1"
                                     Visibility="Collapsed"/>

                        <TextBlock Grid.Column="2" x:Name="AuditProgressPercent"
                                   Foreground="#AAAACC" VerticalAlignment="Center"
                                   FontSize="12" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Row 4: Recent audit reports -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Recent Audit Reports"
                                       Foreground="#5B9BD5" FontWeight="SemiBold"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <Button Grid.Column="1" x:Name="BtnRefreshAuditReports"
                                    Content="Refresh" Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11"/>
                        </Grid>

                        <Border Grid.Row="1" Background="#2D2D44" CornerRadius="6"
                                BorderBrush="#3D3D5C" BorderThickness="1">
                            <ListBox x:Name="AuditReportList"
                                     MaxHeight="120"
                                     Background="#2D2D44"
                                     Foreground="#E0E0E0"
                                     BorderThickness="0"
                                     Margin="4"
                                     FontSize="12"/>
                        </Border>
                    </Grid>

                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#252538" BorderBrush="#3D3D5C" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText"
                       Foreground="#AAAACC"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="12,0"
                       Text="Ready"/>
        </Border>

    </Grid>
</Window>
