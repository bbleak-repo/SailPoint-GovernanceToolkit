<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1E1E2E"
    Foreground="#E0E0E0"
    FontFamily="Segoe UI"
    FontSize="13">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BrushBackground"  Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BrushSurface"     Color="#2D2D44"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt"  Color="#252538"/>
        <SolidColorBrush x:Key="BrushPrimary"     Color="#5B9BD5"/>
        <SolidColorBrush x:Key="BrushSuccess"     Color="#339933"/>
        <SolidColorBrush x:Key="BrushError"       Color="#CC3333"/>
        <SolidColorBrush x:Key="BrushWarning"     Color="#FF9900"/>
        <SolidColorBrush x:Key="BrushText"        Color="#E0E0E0"/>
        <SolidColorBrush x:Key="BrushTextMuted"   Color="#888899"/>
        <SolidColorBrush x:Key="BrushBorder"      Color="#3D3D5C"/>

        <Style x:Key="ToolkitButton" TargetType="Button">
            <Setter Property="Background"      Value="#5B9BD5"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6DACE0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A85BB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3D3D5C"/>
                                <Setter Property="Foreground" Value="#666677"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ToolkitButton}">
            <Setter Property="Background"      Value="#2D2D44"/>
            <Setter Property="BorderBrush"     Value="#5B9BD5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#5B9BD5"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Progress -->
            <RowDefinition Height="Auto"/>  <!-- Result summary -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnRunSelected" Content="Run Selected"
                    Style="{StaticResource ToolkitButton}" Margin="0,0,6,0"/>
            <Button x:Name="BtnRunAll" Content="Run All"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
            <Button x:Name="BtnRunSmoke" Content="Run Smoke"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
            <Separator Width="1" Background="#3D3D5C" Margin="6,2"/>
            <Button x:Name="BtnRefreshCampaigns" Content="Refresh"
                    Style="{StaticResource SecondaryButton}" Margin="6,0,0,0"/>
        </StackPanel>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="#252538" CornerRadius="6"
                BorderBrush="#3D3D5C" BorderThickness="1" Padding="10,6" Margin="0,0,0,8">
            <WrapPanel>
                <TextBlock Text="Filter by Tag:" Foreground="#AAAACC" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="12"/>
                <ComboBox x:Name="TagFilterCombo" Width="150" Margin="0,0,20,0"
                          Background="#2D2D44" Foreground="#E0E0E0"
                          BorderBrush="#3D3D5C" FontSize="12" VerticalContentAlignment="Center"/>

                <TextBlock Text="Priority Min:" Foreground="#AAAACC" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontSize="12"/>
                <TextBox x:Name="TxtPriorityMin" Width="50" Margin="0,0,10,0"
                         Background="#2D2D44" Foreground="#E0E0E0"
                         BorderBrush="#3D3D5C" Text="1" FontSize="12"
                         Padding="4,2" VerticalContentAlignment="Center"/>

                <TextBlock Text="Priority Max:" Foreground="#AAAACC" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontSize="12"/>
                <TextBox x:Name="TxtPriorityMax" Width="50" Margin="0,0,16,0"
                         Background="#2D2D44" Foreground="#E0E0E0"
                         BorderBrush="#3D3D5C" Text="99" FontSize="12"
                         Padding="4,2" VerticalContentAlignment="Center"/>

                <Button x:Name="BtnApplyFilter" Content="Apply"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,3" FontSize="11"/>
            </WrapPanel>
        </Border>

        <!-- Campaign DataGrid -->
        <Border Grid.Row="2" Background="#2D2D44" CornerRadius="6"
                BorderBrush="#3D3D5C" BorderThickness="1">
            <DataGrid x:Name="CampaignGrid"
                      AutoGenerateColumns="False"
                      Background="Transparent"
                      Foreground="#E0E0E0"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3D3D5C"
                      RowBackground="#2D2D44"
                      AlternatingRowBackground="#252538"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      HeadersVisibility="Column"
                      ColumnHeaderHeight="34"
                      RowHeight="28"
                      Margin="2">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"        Value="#252538"/>
                        <Setter Property="Foreground"        Value="#5B9BD5"/>
                        <Setter Property="FontWeight"        Value="SemiBold"/>
                        <Setter Property="Padding"           Value="8,0"/>
                        <Setter Property="BorderThickness"   Value="0,0,1,1"/>
                        <Setter Property="BorderBrush"       Value="#3D3D5C"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Height"            Value="34"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A3A58"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Run"
                                           Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Width="50"/>
                    <DataGridTextColumn Header="Test ID"    Binding="{Binding TestId}"         Width="95"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Test Name"  Binding="{Binding TestName}"        Width="*"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="Type"       Binding="{Binding CampaignType}"    Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Decision"   Binding="{Binding DecisionToMake}"  Width="85"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Reassign"   Binding="{Binding ReassignBeforeDecide}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Priority"   Binding="{Binding Priority}"        Width="68"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tags"       Binding="{Binding Tags}"            Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Certifier"  Binding="{Binding CertifierIdentityId}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Status"     Binding="{Binding Status}"          Width="80"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Result"     Binding="{Binding LastResult}"      Width="90"  IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Progress section -->
        <Grid Grid.Row="3" Margin="0,8,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="CurrentTestLabel" Text=""
                       Foreground="#AAAACC" VerticalAlignment="Center"
                       Margin="0,0,12,0" FontSize="12" MaxWidth="400"
                       TextTrimming="CharacterEllipsis"/>

            <ProgressBar Grid.Column="1" x:Name="SuiteProgressBar"
                         Height="12" Background="#252538"
                         Foreground="#5B9BD5" BorderBrush="#3D3D5C"
                         BorderThickness="1" Visibility="Collapsed"/>

            <TextBlock Grid.Column="2" x:Name="ProgressPercentLabel" Text=""
                       Foreground="#AAAACC" VerticalAlignment="Center"
                       Margin="8,0,0,0" FontSize="11"/>
        </Grid>

        <!-- Result summary -->
        <Border Grid.Row="4" Background="#252538" CornerRadius="6"
                BorderBrush="#3D3D5C" BorderThickness="1" Padding="12,6"
                Visibility="Visible">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Last run: " Foreground="#AAAACC" FontSize="12"/>
                <TextBlock Grid.Column="1" x:Name="ResultSummaryText" Text="No test run yet"
                           Foreground="#AAAACC" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" x:Name="CorrelationIdLabel" Text=""
                           Foreground="#555566" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
